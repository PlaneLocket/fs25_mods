<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<placeable type="productionPoint" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../../shared/xml/schema/placeable.xsd">
    <storeData>
        <name>$l10n_shopItem_cellars</name>
        <functions>
            <function>$l10n_function_winery</function>
        </functions>
        <image>store/store_mckinneycellars.png</image>
        <price>36000</price>
        <lifetime>1000</lifetime>
        <rotation>0</rotation>
        <brand>NONE</brand>
        <species>PLACEABLE</species>
        <category>productionPoints</category>
        <brush>
            <type>placeable</type>
            <category>production</category>
            <tab>factories</tab>
        </brush>
        <vertexBufferMemoryUsage>293632</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>70656</indexBufferMemoryUsage>
        <textureMemoryUsage>524288</textureMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
        <audioMemoryUsage>0</audioMemoryUsage>
    </storeData>

    <base>
        <filename>i3d/mckinneycellars.i3d</filename>
        <canBeRenamed>true</canBeRenamed>
    </base>

    <placement useRandomYRotation="false" useManualYRotation="true" >
        <testAreas>
            <testArea startNode="testAreaStart01" endNode="testAreaEnd01" />
        </testAreas>
        <sounds>
            <place template="smallImp"/>
        </sounds>
    </placement>

    <clearAreas>
        <clearArea startNode="clearAreaStart01" widthNode="clearAreaWidth01" heightNode="clearAreaHeight01"/>
    </clearAreas>

    <leveling requireLeveling="true" maxSmoothDistance="10" maxSlope="75" maxEdgeAngle="30" >
        <levelAreas>
            <levelArea startNode="levelAreaStart01" widthNode="levelAreaWidth01" heightNode="levelAreaHeight01" groundType="asphalt"/>
        </levelAreas>
        <paintAreas>
            <paintArea startNode="paintAreaStart01" widthNode="paintAreaWidth01" heightNode="paintAreaHeight01" groundType="asphalt"/>
        </paintAreas>
    </leveling>

    <indoorAreas>
        <indoorArea startNode="indoorAreaStart01" widthNode="indoorAreaWidth01" heightNode="indoorAreaHeight01" />
    </indoorAreas>

    <tipOcclusionUpdateAreas>
        <tipOcclusionUpdateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
    </tipOcclusionUpdateAreas>

    <ai>
        <updateAreas>
            <updateArea startNode="tipOcclusionUpdateAreaStart01" endNode="tipOcclusionUpdateAreaEnd01" />
        </updateAreas>
    </ai>

    <infoTrigger triggerNode="infoTrigger"/>

    <hotspots>
        <hotspot type="PRODUCTION_POINT" linkNode="unloadTriggerMarker" teleportNode="playerTriggerMarker" />
    </hotspots>

    <triggerMarkers>
        <triggerMarker node="warningStripes01"/>
        <triggerMarker node="warningStripes02"/>
        <triggerMarker node="unloadTriggerMarker" adjustToGround="true" filename="$data/shared/assets/marker/markerIconUnload.i3d"/>
        <triggerMarker node="playerTriggerMarker" adjustToGround="true" filename="$data/shared/assets/marker/markerIconWrench.i3d"/>
    </triggerMarkers>

    <dynamicallyLoadedParts>
        <dynamicallyLoadedPart node="0" linkNode="lightSwitch01" filename="$data/shared/assets/lights/rudolfHormann/powerSwitch.i3d" />
    </dynamicallyLoadedParts>

    <lights>
        <sharedLight filename="$data/shared/assets/lights/terraLed/fluorescentTube50W.xml" linkNode="lightNode01" groupIndex="1"/>

        <realLights>
            <low>
                <light node="realLightsLow" groupIndex="1"/>
            </low>
            <high>
                <light node="realLightsHigh" groupIndex="1"/>
            </high>
        </realLights>

        <group name="$l10n_action_placeableLightShed" triggerNode="lightTrigger01"/>
    </lights>

    <productionPoint>
        <productions>
            <production id="MEAD" name="$l10n_fillType_mead" cyclesPerHour="15" costsPerActiveHour="4">
				<inputs>
					<input fillType="HONEY" amount="15"/>
					<input fillType="WATER" amount="15"/>
					<input fillType="YEAST" amount="5"/>
				</inputs>
				<outputs>
					<output fillType="MEAD" amount="30"/>
				</outputs>
			</production>
			<production id="WINE" name="$l10n_fillType_wine" cyclesPerHour="8" costsPerActiveHour="4">
				<inputs>
					<input fillType="GRAPE" amount="40"/>
					<input fillType="SUGAR" amount="20"/>
					<input fillType="YEAST" amount="5"/>
				</inputs>
				<outputs>
					<output fillType="WINE" amount="40"/>
			</outputs>
			</production>
			<production id="STRAWBERRYMELOMEL" name="$l10n_fillType_strawberryMelomel" cyclesPerHour="10" costsPerActiveHour="4">
				<inputs>
					<input fillType="HONEY" amount="15"/>
					<input fillType="STRAWBERRY" amount="15"/>
					<input fillType="WATER" amount="15"/>
					<input fillType="SUGAR" amount="15"/>
					<input fillType="YEAST" amount="5"/>
				</inputs>
				<outputs>
					<output fillType="STRAWBERRYMELOMEL" amount="45"/>
				</outputs>
			</production>
        </productions>

        <storage isExtension="false" fillLevelSyncThreshold="50">
			<capacity fillType="HONEY" capacity="80000"/>
			<capacity fillType="GRAPE" capacity="80000"/>
			<capacity fillType="WATER" capacity="80000"/>
			<capacity fillType="MEAD" capacity="80000"/>
			<capacity fillType="SUGAR" capacity="80000"/>
			<capacity fillType="WINE" capacity="80000"/>
			<capacity fillType="STRAWBERRY" capacity="80000"/>
			<capacity fillType="STRAWBERRYMELOMEL" capacity="80000"/>
			<capacity fillType="YEAST" capacity="80000"/>
        </storage>

        <sellingStation node="sellingStation" supportsExtension="false" allowMissions="false">
            <unloadTrigger exactFillRootNode="exactFillNode" aiNode="unloadTriggerAINode" fillTypes="YEAST HONEY GRAPE WATER SUGAR STRAWBERRY"/>
			<palletTrigger triggerNode="palletTrigger" aiNode="unloadTriggerAINode" fillTypes="YEAST HONEY GRAPE WATER SUGAR STRAWBERRY"/>
        </sellingStation>

        <palletSpawner>
            <spawnPlaces>
                <spawnPlace startNode="palletAreaStart01" endNode="palletAreaEnd01"/>
                <spawnPlace startNode="palletAreaStart02" endNode="palletAreaEnd02"/>
            </spawnPlaces>
        </palletSpawner>

        <playerTrigger node="playerTrigger" />
        <sounds>
            <idle   template="placeableSmallIdleGeneric" linkNode="0>"/>
            <active template="raisinWork" linkNode="0>" pitchScale="1.2" innerRadius="2" outerRadius="15" volumeScale="0.9"/>
        </sounds>
    </productionPoint>

	<animatedObjects>
		<animatedObject saveId="bigDoors" >
            <animation duration="4">
                <part node="door1">
                    <keyFrame time="0.0" translation="-5.138 0 -2.568" />
					<keyFrame time="1.0" translation="-5.138 0 -4.901" />
                </part>
				<part node="door2">
                    <keyFrame time="0.0" translation="-5.138 0 0.702" />
					<keyFrame time="1.0" translation="-5.138 0 3.084" />
                </part>
            </animation>
            <controls triggerNode="bigDoorsTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving linkNode="bigDoorsTrigger" template="woodDoorSqueaksLarge" />
                <posEnd linkNode="bigDoorsTrigger" template="woodDoorOpen" />
                <negEnd linkNode="bigDoorsTrigger" template="woodDoorClose" />
            </sounds>
        </animatedObject>		
		<animatedObject saveId="smallDoors" >
            <animation duration="4">
                <part node="open1">
                    <keyFrame time="0.2" rotation="0 0 0"/>
					<keyFrame time="1.0" rotation="0 110 0"/>
                </part>
				<part node="open2">
                    <keyFrame time="0.0" rotation="0 0 0"/>
					<keyFrame time="1.0" rotation="0 -110 0"/>
                </part>
            </animation>
            <controls triggerNode="smallDoorsTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_openGate" negText="action_closeGate" />
            <sounds>
                <moving  template="woodDoorSqueaksSmall" linkNode="smallDoorsTrigger" volumeScale="0.6" pitchScale="0.8"/>
                <posEnd  template="woodDoorOpen"    linkNode="smallDoorsTrigger" volumeScale="0.2"/>
                <negEnd  template="woodDoorCloseRandom"   linkNode="smallDoorsTrigger"/>
            </sounds>
        </animatedObject>
		<animatedObject saveId="Lights" >
            <animation duration="0.1">
                <part node="light1">
                    <keyFrame time="0.0" visibility="false" />
                    <keyFrame time="1.0" visibility="true"/>
                </part>                
				<part node="light2">
                    <keyFrame time="0.0" visibility="false" />
                    <keyFrame time="1.0" visibility="true"/>
                </part>                
				<part node="light3">
                    <keyFrame time="0.0" visibility="false" />
                    <keyFrame time="1.0" visibility="true"/>
                </part>                
				<part node="light4">
                    <keyFrame time="0.0" visibility="false" />
                    <keyFrame time="1.0" visibility="true"/>
                </part>                
				<part node="light5">
                    <keyFrame time="0.0" visibility="false" />
                    <keyFrame time="1.0" visibility="true"/>
                </part>                             			
                <part node="switch">
                    <keyFrame time="0.0" rotation="0 0 0"/>
                    <keyFrame time="1.0" rotation="0 0 -10"/>
                </part>
            </animation>
            <controls triggerNode="lightTrigger" posAction="ACTIVATE_HANDTOOL" posText="action_lightSwitchON" negText="action_lightSwitchOFF" />
            <sounds>
                 <moving linkNode="switch" template="lizardFloodLight" />
            </sounds>
        </animatedObject>
    </animatedObjects>
    <i3dMappings>
        <i3dMapping id="clearAreaStart01" node="0>0|0" />
        <i3dMapping id="clearAreaWidth01" node="0>0|0|0" />
        <i3dMapping id="clearAreaHeight01" node="0>0|0|1" />
        <i3dMapping id="levelAreaStart01" node="0>1|0" />
        <i3dMapping id="levelAreaWidth01" node="0>1|0|0" />
        <i3dMapping id="levelAreaHeight01" node="0>1|0|1" />
        <i3dMapping id="paintAreaStart01" node="0>2|0" />
        <i3dMapping id="paintAreaWidth01" node="0>2|0|0" />
        <i3dMapping id="paintAreaHeight01" node="0>2|0|1" />
        <i3dMapping id="indoorAreaStart01" node="0>3|0" />
        <i3dMapping id="indoorAreaWidth01" node="0>3|0|0" />
        <i3dMapping id="indoorAreaHeight01" node="0>3|0|1" />
        <i3dMapping id="testAreaStart01" node="0>4|0" />
        <i3dMapping id="testAreaEnd01" node="0>4|0|0" />
        <i3dMapping id="tipOcclusionUpdateAreaStart01" node="0>5|0" />
        <i3dMapping id="tipOcclusionUpdateAreaEnd01" node="0>5|0|0" />
        <i3dMapping id="lightTrigger01" node="0>6|3" />
        <i3dMapping id="infoTrigger" node="0>7" />
        <i3dMapping id="sellingStation" node="0>8" />
        <i3dMapping id="exactFillNode" node="0>8|0" />
        <i3dMapping id="unloadTriggerMarker" node="0>8|1" />
        <i3dMapping id="unloadTriggerAINode" node="0>8|2" />
        <i3dMapping id="palletTrigger" node="0>8|3" />
        <i3dMapping id="playerTrigger" node="0>9|0" />
        <i3dMapping id="playerTriggerMarker" node="0>9|1" />
        <i3dMapping id="palletSpawner" node="0>10" />
        <i3dMapping id="palletAreaStart01" node="0>10|0" />
        <i3dMapping id="palletAreaEnd01" node="0>10|0|0" />
        <i3dMapping id="palletAreaStart02" node="0>10|1" />
        <i3dMapping id="palletAreaEnd02" node="0>10|1|0" />
        <i3dMapping id="warningStripes01" node="0>11|0" />
        <i3dMapping id="warningStripes02" node="0>11|1" />
		<i3dMapping id="door1" node="0>11|0|9|0|0" />
		<i3dMapping id="door2" node="0>11|0|9|0|1" />
		<i3dMapping id="bigDoorsTrigger" node="0>11|0|9|2" />	
		<i3dMapping id="open1" node="0>11|0|9|1|0" />
		<i3dMapping id="open2" node="0>11|0|9|1|1" />
		<i3dMapping id="smallDoorsTrigger" node="0>11|0|9|3" />
		<i3dMapping id="light1" node="0>13|2|1" />
		<i3dMapping id="light2" node="0>13|3|1" />
		<i3dMapping id="light3" node="0>13|4|1" />
		<i3dMapping id="light4" node="0>13|5|1" />
		<i3dMapping id="light5" node="0>13|6|1" />
		<i3dMapping id="switch" node="0>13|0|0" />
		<i3dMapping id="lightTrigger" node="0>9|1" />
	
    </i3dMappings>
</placeable>
