<?xml version="1.0" encoding="utf-8" standalone="no" ?>
<vehicle type="pallet" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="../../../../shared/xml/schema/vehicle.xsd">
    <annotation>Copyright (C) GIANTS Software GmbH, All Rights Reserved.</annotation>

    <storeData>
        <name>$l10n_storeItem_yeastPallet</name>
        <image>pallets/yeastPallet/store_yeastPallet.dds</image>
        <specs>
            <weight ignore="true"/>
        </specs>
        <functions>
            <function>$l10n_function_seeds</function>
        </functions>
        <price>4500</price>
        <category>pallets palletSeeds</category>
        <brand>NONE</brand>
        <showInStore>false</showInStore>
        <canBeSold>false</canBeSold>
        <allowLeasing>false</allowLeasing>
        <financeCategory>OTHER</financeCategory>
        <shopHeight>1.5</shopHeight>
    </storeData>

    <base>
        <typeDesc>$l10n_typeDesc_pallet</typeDesc>
        <filename>pallets/yeastPallet/yeastPallet.i3d</filename>
        <size width="1.3" length="0.9" height="0.8" />
        <canBeReset>false</canBeReset>
        <components maxMass="850">
            <component centerOfMass="0 0.1 0" solverIterationCount="10" mass="60"/>
        </components>
        <showInVehicleMenu>false</showInVehicleMenu>
        <mapHotspot available="false" />
        <input allowed="false"/>
    </base>

    <animations>
        <animation name="fillAnimation">
            <part node="contentCollision" startTime="0.000" endTime="1.0" startScale="1 0.05 1" endScale="1 1 1" />
            <part node="mineralFeedBags"  startTime="0.000" endTime="1.0" shaderParameter="hideByIndex" shaderStartValues="41.01 0 0 0" shaderEndValues="-0.01 0 0 0"/>
        </animation>
    </animations>

    <pallet fillUnitIndex="1" linkNode="yeastPallet_component1">
        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletNew_diffuse.dds"/>
        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletMiddle_diffuse.dds"/>
        <texture diffuse="$data/objects/pallets/shared/euroPallet/euroPalletOld_diffuse.dds"/>
    </pallet>

    <fillUnit>
        <fillUnitConfigurations>
            <fillUnitConfiguration>
                <fillUnits removeVehicleIfEmpty="true">
                    <fillUnit unitTextOverride="$l10n_unit_literShort" fillTypes="YEAST" startFillType="YEAST" capacity="1000" startFillLevel="1000" ignoreFillLimit="true">
                        <fillLevelAnimation name="fillAnimation" resetOnEmpty="true" />
                    </fillUnit>
                </fillUnits>
            </fillUnitConfiguration>
        </fillUnitConfigurations>
    </fillUnit>

    <fillTriggerVehicle triggerNode="fillTrigger" fillUnitIndex="1" litersPerSecond="200"/>

    <dynamicMount triggerNode="dynamicMountTrigger" triggerForceAcceleration="6" additionalMountDistance="0.75" jointTransY="0.11" jointLimitToRotY="true"/>

    <tensionBeltObject>
        <meshNodes>
            <meshNode node="contentCollision"/>
        </meshNodes>
    </tensionBeltObject>

    <i3dMappings>
        <i3dMapping id="yeastPallet_component1" node="0>" />
        <i3dMapping id="dynamicMountTrigger" node="0>0" />
        <i3dMapping id="fillTrigger" node="0>1" />
        <i3dMapping id="dischargeNode" node="0>2" />
        <i3dMapping id="mineralFeedBags" node="0>3" />
        <i3dMapping id="contentCollision" node="0>4|2" />
    </i3dMappings>
</vehicle>
